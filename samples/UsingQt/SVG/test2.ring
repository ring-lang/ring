load "guilib.ring"

app = new QApp {

	win = new QWidget() {
		setWindowTitle("SVG Generated by RingQt")
		resize(400, 300)
		createSVGFile()
		s = new QSvgWidget(win) {
			setStyleSheet("background-color:white;")
			loadFile("output.svg")
		}
		show()
	}
	exec()
}

func createSVGFile

	oGenerator = new QSvgGenerator() {
		setFileName("output.svg")
		setSize(new QSize(400, 300))
		setTitle("RingQt SVG Example")
		setDescription("Generated using QSvgGenerator from Ring")
	}

	oPainter = new QPainter() {

		begin(oGenerator)

		# Draw sky background
		color = new QColor() { setRGB(135, 206, 235, 255) }
		pen = new QPen() { setColor(color) setWidth(0) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setpen(pen)
		setBrush(brush)
		drawRect(0, 0, 400, 300)

		# Draw ground
		color = new QColor() { setRGB(34, 139, 34, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawRect(0, 220, 400, 80)

		# Draw sun
		color = new QColor() { setRGB(255, 215, 0, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawEllipse(310, 20, 70, 70)

		# Draw house body
		color = new QColor() { setRGB(178, 34, 34, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		penColor = new QColor() { setRGB(0, 0, 0, 255) }
		pen = new QPen() { setColor(penColor) setWidth(2) }
		setpen(pen)
		setBrush(brush)
		drawRect(100, 130, 150, 90)

		# Draw door
		color = new QColor() { setRGB(139, 90, 43, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawRect(155, 170, 40, 50)

		# Draw window
		color = new QColor() { setRGB(173, 216, 230, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawRect(210, 150, 30, 30)

		# Draw tree trunk
		color = new QColor() { setRGB(139, 69, 19, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawRect(30, 160, 15, 60)

		# Draw tree top
		color = new QColor() { setRGB(0, 128, 0, 255) }
		brush = new QBrush() { setColor(color) setStyle(1) }
		setBrush(brush)
		drawEllipse(10, 110, 55, 60)

		# Draw text
		textColor = new QColor() { setRGB(255, 255, 255, 255) }
		pen = new QPen() { setColor(textColor) setWidth(1) }
		setpen(pen)
		oFont = new QFont("Arial", 14, 0, 0)
		setFont(oFont)
		drawText(100, 280, "Generated by RingQt!")

		endpaint()
	}

